<div class="toast" id="toast"></div>

<script>
(function() {
  'use strict';

  // ============ BACKEND CONFIG (matches CRM pattern) ============
  var API_BASE = window.location.origin;
  var API_TOKEN = "mikeys-stats-2026";
  var ENDPOINT = "/.netlify/functions/calendar";
  var LOCAL_KEY = "mikeys_calendar_events_v2";
  var useServer = window.location.protocol.indexOf('http') === 0 && window.location.hostname !== '';

  var state = {
    view: 'week',
    mode: 'owner',          // 'owner' or 'customer'
    cursor: new Date(),
    events: [],
    editingId: null,
    selectedType: 'job',
    dragging: null,
    pendingBookingSlot: null
  };

  // ============ STORAGE ============
  function apiCall(method, body) {
    var opts = { method: method, headers: { 'Content-Type':'application/json', 'x-api-token': API_TOKEN } };
    if (body) opts.body = JSON.stringify(body);
    return fetch(API_BASE + ENDPOINT, opts).then(function(r) {
      if (!r.ok) throw new Error(r.statusText);
      return r.json();
    });
  }
  function saveLocal() { try { localStorage.setItem(LOCAL_KEY, JSON.stringify(state.events)); } catch (e) {} }
  function loadLocal() {
    try { var raw = localStorage.getItem(LOCAL_KEY); return raw ? JSON.parse(raw) : []; } catch (e) { return []; }
  }
  function loadEvents() {
    if (!useServer) { state.events = loadLocal(); setBadge('Local only', 'local'); return Promise.resolve(); }
    return apiCall('GET').then(function(data) {
      state.events = (data && data.events) ? data.events : [];
      saveLocal();
      setBadge('Synced', 'connected');
    }).catch(function() {
      state.events = loadLocal();
      setBadge('Local only', 'local');
    });
  }
  function persistEvent(ev) {
    var idx = state.events.findIndex(function(x){ return x.id === ev.id; });
    if (idx >= 0) state.events[idx] = ev; else state.events.push(ev);
    saveLocal();
    if (!useServer) return Promise.resolve();
    return apiCall('PUT', { event: ev }).catch(function(){});
  }
  function removeEventServer(id) {
    state.events = state.events.filter(function(x){ return x.id !== id; });
    saveLocal();
    if (!useServer) return Promise.resolve();
    return apiCall('DELETE', { id: id }).catch(function(){});
  }
  function setBadge(text, cls) {
    var b = document.getElementById('storageBadge');
    b.textContent = text;
    b.classList.remove('connected','local');
    if (cls) b.classList.add(cls);
  }

  // ============ DATE UTILS ============
  function startOfWeek(d) {
    var x = new Date(d); var day = x.getDay();
    var diff = (day === 0 ? -6 : 1 - day);
    x.setDate(x.getDate() + diff); x.setHours(0,0,0,0);
    return x;
  }
  function startOfMonth(d) { return new Date(d.getFullYear(), d.getMonth(), 1); }
  function addDays(d, n) { var x = new Date(d); x.setDate(x.getDate()+n); return x; }
  function sameDay(a, b) {
    return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
  }
  function fmtDateKey(d) {
    return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
  }
  function fmtTime(d) {
    var h = d.getHours(); var m = d.getMinutes();
    var ap = h >= 12 ? 'pm' : 'am'; var h12 = h % 12 || 12;
    return h12 + (m ? ':' + String(m).padStart(2,'0') : '') + ap;
  }
  function fmtRangeLabel() {
    var d = state.cursor;
    if (state.view === 'day') return d.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
    if (state.view === 'week') {
      var s = startOfWeek(d); var e = addDays(s, 6);
      var sameMonth = s.getMonth() === e.getMonth();
      var sameYear = s.getFullYear() === e.getFullYear();
      return s.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' – ' +
             (sameMonth ? e.getDate() : e.toLocaleDateString('en-US',{month:'short',day:'numeric'})) +
             (sameYear ? ', ' + e.getFullYear() : '');
    }
    return d.toLocaleDateString('en-US',{month:'long',year:'numeric'});
  }

  function escapeHtml(s) {
    return String(s || '').replace(/[&<>"']/g, function(c){
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
    });
  }

  // ============ RENDERING ============
  function render() {
    document.getElementById('rangeLabel').textContent = fmtRangeLabel();
    Array.prototype.forEach.call(document.querySelectorAll('.view-switcher button'), function(b){
      b.classList.toggle('active', b.dataset.view === state.view);
    });
    var area = document.getElementById('calendarArea');
    area.innerHTML = '';
    if (state.view === 'day') renderDayOrWeek(1);
    else if (state.view === 'week') renderDayOrWeek(7);
    else renderMonth();
    updateSidebar();
    updatePendingBadge();
  }

  function renderDayOrWeek(dayCount) {
    var area = document.getElementById('calendarArea');
    var grid = document.createElement('div');
    grid.className = 'time-grid ' + (dayCount === 1 ? 'day' : 'week');
    var startDate = dayCount === 1 ? state.cursor : startOfWeek(state.cursor);

    var th = document.createElement('div');
    th.className = 'time-col-header'; th.textContent = 'PST';
    grid.appendChild(th);

    var days = [];
    for (var i = 0; i < dayCount; i++) {
      var d = addDays(startDate, i); days.push(d);
      var dh = document.createElement('div');
      dh.className = 'day-col-header' + (sameDay(d, new Date()) ? ' today' : '');
      dh.innerHTML = d.toLocaleDateString('en-US',{weekday:'short'}) +
                     '<span class="day-num">' + d.getDate() + '</span>';
      grid.appendChild(dh);
    }

    var timeCol = document.createElement('div');
    for (var h = 7; h <= 21; h++) {
      var t = document.createElement('div');
      t.className = 'time-slot';
      t.textContent = (h % 12 || 12) + (h >= 12 ? 'p' : 'a');
      timeCol.appendChild(t);
    }
    grid.appendChild(timeCol);

    days.forEach(function(d, idx) {
      var col = document.createElement('div');
      col.className = 'day-col';
      for (var h = 7; h <= 21; h++) {
        var cell = document.createElement('div');
        cell.className = 'hour-cell';
        cell.dataset.dateKey = fmtDateKey(d);
        cell.dataset.hour = h;

        (function(dCopy, hour) {
          // Customer mode: check availability
          if (state.mode === 'customer') {
            var isBooked = state.events.some(function(ev) {
              if (!sameDay(new Date(ev.start), dCopy)) return false;
              var es = new Date(ev.start), ee = new Date(ev.end);
              var slotStart = new Date(dCopy); slotStart.setHours(hour, 0, 0, 0);
              var slotEnd = new Date(slotStart.getTime() + 3600000);
              return es < slotEnd && ee > slotStart;
            });
            // Working hours: Wed-Sat, 9am-5pm (latest start)
            var dow = dCopy.getDay(); // 0=Sun 3=Wed 6=Sat
            var inWorkingHours = (dow >= 3 && dow <= 6) && hour >= 9 && hour <= 17;
            var isPast = dCopy < new Date(new Date().toDateString()) ||
                         (sameDay(dCopy, new Date()) && hour <= new Date().getHours());

            if (isBooked || !inWorkingHours || isPast) {
              cell.classList.add('customer-blocked');
            } else {
              cell.classList.add('customer-available');
              cell.addEventListener('click', function() {
                openBookingModal(dCopy, hour);
              });
            }
            return; // skip owner-mode handlers
          }

          // Owner mode handlers
          cell.addEventListener('click', function(e) {
            if (e.target !== cell) return;
            openModalForNew(dCopy, hour);
          });
          cell.addEventListener('dragover', function(e) { e.preventDefault(); cell.classList.add('drop-target'); });
          cell.addEventListener('dragleave', function() { cell.classList.remove('drop-target'); });
          cell.addEventListener('drop', function(e) {
            e.preventDefault();
            cell.classList.remove('drop-target');
            handleDrop(dCopy, hour);
          });
        })(d, h);

        col.appendChild(cell);
      }

      var dayEvents = state.events.filter(function(ev) { return sameDay(new Date(ev.start), d); });
      dayEvents.forEach(function(ev){ renderTimedEvent(col, ev); });

      if (sameDay(d, new Date())) {
        var now = new Date();
        var mins = (now.getHours() - 7) * 60 + now.getMinutes();
        if (mins >= 0 && mins <= 14*60) {
          var line = document.createElement('div');
          line.className = 'now-line'; line.style.top = (mins / 60 * 40) + 'px';
          col.appendChild(line);
        }
      }
      grid.appendChild(col);
    });
    area.appendChild(grid);
  }

  function renderTimedEvent(col, ev) {
    var start = new Date(ev.start);
    var end = new Date(ev.end);
    var startMin = (start.getHours() - 7) * 60 + start.getMinutes();
    var duration = (end - start) / 60000;
    if (startMin < 0) return;
    var el = document.createElement('div');
    el.className = 'event ' + (ev.type || 'job') + (ev.status === 'pending' ? ' pending' : '');
    el.style.top = (startMin / 60 * 40) + 'px';
    el.style.height = Math.max(24, duration / 60 * 40) + 'px';
    var prefix = ev.status === 'pending' ? '⏳ ' : '';
    el.innerHTML = '<div class="event-title">' + prefix + escapeHtml(ev.title) + '</div>' +
                   '<div class="event-time">' + fmtTime(start) + ' – ' + fmtTime(end) + '</div>';
    el.draggable = (state.mode === 'owner');
    el.addEventListener('click', function(e){
      e.stopPropagation();
      if (state.mode === 'owner') openModalForEdit(ev.id);
    });
    if (state.mode === 'owner') {
      el.addEventListener('dragstart', function(e) {
        state.dragging = { mode: 'move', id: ev.id };
        e.dataTransfer.effectAllowed = 'move';
        el.classList.add('dragging');
      });
      el.addEventListener('dragend', function() {
        el.classList.remove('dragging');
        state.dragging = null;
      });
      attachTouchMoveDrag(el, ev.id);
    }
    col.appendChild(el);
  }

  function renderMonth() {
    var area = document.getElementById('calendarArea');
    var grid = document.createElement('div');
    grid.className = 'month-grid';
    ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(function(d){
      var h = document.createElement('div'); h.className = 'month-header'; h.textContent = d;
      grid.appendChild(h);
    });
    var first = startOfMonth(state.cursor);
    var gridStart = startOfWeek(first);
    for (var i = 0; i < 42; i++) {
      var d = addDays(gridStart, i);
      var cell = document.createElement('div');
      cell.className = 'month-cell' +
        (sameDay(d, new Date()) ? ' today' : '') +
        (d.getMonth() !== state.cursor.getMonth() ? ' other-month' : '');
      cell.dataset.dateKey = fmtDateKey(d);
      (function(dCopy) {
        cell.innerHTML = '<div class="month-day-num">' + dCopy.getDate() + '</div>';
        var dayEvents = state.events.filter(function(ev){ return sameDay(new Date(ev.start), dCopy); })
                                    .sort(function(a,b){ return new Date(a.start) - new Date(b.start); });
        dayEvents.slice(0, 3).forEach(function(ev){
          var chip = document.createElement('div');
          chip.className = 'month-event ' + (ev.type || 'job') + (ev.status === 'pending' ? ' pending' : '');
          var prefix = ev.status === 'pending' ? '⏳ ' : '';
          chip.textContent = prefix + fmtTime(new Date(ev.start)) + ' ' + ev.title;
          chip.addEventListener('click', function(e){
            e.stopPropagation();
            if (state.mode === 'owner') openModalForEdit(ev.id);
          });
          cell.appendChild(chip);
        });
        if (dayEvents.length > 3) {
          var more = document.createElement('div');
          more.className = 'month-more'; more.textContent = '+' + (dayEvents.length - 3) + ' more';
          cell.appendChild(more);
        }
        if (state.mode === 'owner') {
          cell.addEventListener('click', function(e) {
            if (e.target !== cell && !e.target.classList.contains('month-day-num')) return;
            openModalForNew(dCopy, 9);
          });
          cell.addEventListener('dragover', function(e){ e.preventDefault(); cell.classList.add('drop-target'); });
          cell.addEventListener('dragleave', function(){ cell.classList.remove('drop-target'); });
          cell.addEventListener('drop', function(e) {
            e.preventDefault();
            cell.classList.remove('drop-target');
            handleDrop(dCopy, 9);
          });
        } else {
          cell.addEventListener('click', function() {
            state.view = 'day'; state.cursor = dCopy; render();
          });
        }
      })(d);
      grid.appendChild(cell);
    }
    area.appendChild(grid);
  }

  // ============ SIDEBAR STATS & UPCOMING ============
  function updateSidebar() {
    var now = new Date();
    var weekStart = startOfWeek(now);
    var weekEnd = addDays(weekStart, 7);

    var weekJobs = state.events.filter(function(ev) {
      if (ev.type !== 'job' || ev.status === 'pending') return false;
      var d = new Date(ev.start);
      return d >= weekStart && d < weekEnd;
    });
    var revenue = weekJobs.reduce(function(sum, ev){ return sum + (parseFloat(ev.price) || 0); }, 0);
    var hours = weekJobs.reduce(function(sum, ev) {
      return sum + (new Date(ev.end) - new Date(ev.start)) / 3600000;
    }, 0);
    var todayJobs = state.events.filter(function(ev) {
      return ev.type === 'job' && ev.status !== 'pending' && sameDay(new Date(ev.start), now);
    });

    document.getElementById('statRevenue').textContent = '$' + Math.round(revenue);
    document.getElementById('statRevenueSub').textContent = weekJobs.length + (weekJobs.length === 1 ? ' job' : ' jobs');
    document.getElementById('statHours').textContent = hours.toFixed(1);
    document.getElementById('statToday').textContent = todayJobs.length;
    document.getElementById('statTodaySub').textContent = todayJobs.length === 1 ? 'job today' : 'jobs today';

    // Next job
    var nextJob = state.events
      .filter(function(ev){ return ev.type === 'job' && ev.status !== 'pending' && new Date(ev.start) > now; })
      .sort(function(a,b){ return new Date(a.start) - new Date(b.start); })[0];
    if (nextJob) {
      var d = new Date(nextJob.start);
      document.getElementById('statNext').textContent = fmtTime(d);
      document.getElementById('statNextSub').textContent =
        sameDay(d, now) ? 'Today' :
        sameDay(d, addDays(now,1)) ? 'Tomorrow' :
        d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
    } else {
      document.getElementById('statNext').textContent = '—';
      document.getElementById('statNextSub').textContent = 'no upcoming';
    }

    // Upcoming list
    var upcoming = state.events
      .filter(function(ev) {
        var d = new Date(ev.start);
        return d >= now && d < addDays(now, 7);
      })
      .sort(function(a,b){ return new Date(a.start) - new Date(b.start); })
      .slice(0, 10);

    var list = document.getElementById('upcomingList');
    if (upcoming.length === 0) {
      list.innerHTML = '<div class="upcoming-empty">No events in the next 7 days</div>';
    } else {
      list.innerHTML = '';
      upcoming.forEach(function(ev) {
        var d = new Date(ev.start);
        var when = sameDay(d, now) ? 'Today · ' :
                   sameDay(d, addDays(now,1)) ? 'Tomorrow · ' :
                   d.toLocaleDateString('en-US',{weekday:'short', month:'short', day:'numeric'}) + ' · ';
        var item = document.createElement('div');
        item.className = 'upcoming-item ' + (ev.type || 'job') + (ev.status === 'pending' ? ' pending' : '');
        var prefix = ev.status === 'pending' ? '⏳ ' : '';
        item.innerHTML = '<div class="upcoming-when">' + when + fmtTime(d) + '</div>' +
                        '<div class="upcoming-title">' + prefix + escapeHtml(ev.title) + '</div>' +
                        (ev.address ? '<div class="upcoming-addr">📍 ' + escapeHtml(ev.address) + '</div>' : '');
        item.addEventListener('click', function(){ openModalForEdit(ev.id); });
        list.appendChild(item);
      });
    }
  }

  // ============ DRAG (desktop + mobile touch) ============
  Array.prototype.forEach.call(document.querySelectorAll('.preset[data-draggable="true"]'), function(p) {
    p.draggable = true;
    p.addEventListener('dragstart', function(e) {
      state.dragging = { mode: 'new', presetType: p.dataset.type };
      e.dataTransfer.effectAllowed = 'copy';
      p.classList.add('dragging');
    });
    p.addEventListener('dragend', function() {
      p.classList.remove('dragging');
      state.dragging = null;
    });
    attachTouchPresetDrag(p);
  });

  function handleDrop(date, hour) {
    if (!state.dragging) return;
    if (state.dragging.mode === 'new') {
      var start = new Date(date);
      start.setHours(hour, 0, 0, 0);
      var end = new Date(start.getTime() + 2 * 3600 * 1000);
      var newEv = {
        id: 'ev_' + Date.now() + '_' + Math.random().toString(36).slice(2,7),
        type: state.selectedType = state.dragging.presetType,
        title: state.dragging.presetType === 'job' ? 'New Job' : 'Blocked',
        address: '',
        price: '',
        start: start.toISOString(),
        end: end.toISOString(),
        notes: '',
        status: 'confirmed',
        updated: Date.now()
      };
      persistEvent(newEv).then(function(){
        render();
        openModalForEdit(newEv.id);
      });
    } else if (state.dragging.mode === 'move') {
      var ev = state.events.find(function(x){ return x.id === state.dragging.id; });
      if (!ev) return;
      var oldStart = new Date(ev.start);
      var oldEnd = new Date(ev.end);
      var duration = oldEnd - oldStart;
      var newStart = new Date(date);
      newStart.setHours(hour, oldStart.getMinutes(), 0, 0);
      ev.start = newStart.toISOString();
      ev.end = new Date(newStart.getTime() + duration).toISOString();
      ev.updated = Date.now();
      persistEvent(ev).then(function(){
        toast('Moved to ' + newStart.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' ' + fmtTime(newStart));
        render();
      });
    }
  }

  function attachTouchPresetDrag(el) {
    var ghost = null;
    el.addEventListener('touchstart', function(e) {
      var t = e.touches[0];
      ghost = document.createElement('div');
      ghost.className = 'drag-ghost' + (el.dataset.type === 'personal' ? ' personal' : '');
      ghost.textContent = el.dataset.type === 'job' ? 'Job' : 'Personal';
      ghost.style.left = (t.clientX + 10) + 'px';
      ghost.style.top = (t.clientY + 10) + 'px';
      document.body.appendChild(ghost);
      state.dragging = { mode: 'new', presetType: el.dataset.type };
      el.classList.add('dragging');
    }, { passive: true });
    el.addEventListener('touchmove', function(e) {
      if (!ghost) return;
      e.preventDefault();
      var t = e.touches[0];
      ghost.style.left = (t.clientX + 10) + 'px';
      ghost.style.top = (t.clientY + 10) + 'px';
      highlightTargetAt(t.clientX, t.clientY);
    }, { passive: false });
    el.addEventListener('touchend', function(e) {
      el.classList.remove('dragging');
      if (ghost) { ghost.remove(); ghost = null; }
      var t = (e.changedTouches && e.changedTouches[0]);
      if (t) dropAt(t.clientX, t.clientY);
      clearDropHighlights();
      state.dragging = null;
    });
    el.addEventListener('touchcancel', function() {
      if (ghost) { ghost.remove(); ghost = null; }
      el.classList.remove('dragging');
      clearDropHighlights();
      state.dragging = null;
    });
  }

  function attachTouchMoveDrag(el, id) {
    var ghost = null;
    var longPressTimer = null;
    var dragActive = false;
    el.addEventListener('touchstart', function(e) {
      var t = e.touches[0];
      longPressTimer = setTimeout(function() {
        dragActive = true;
        state.dragging = { mode: 'move', id: id };
        ghost = document.createElement('div');
        var ev = state.events.find(function(x){ return x.id === id; });
        ghost.className = 'drag-ghost' + (ev && ev.type === 'personal' ? ' personal' : '');
        ghost.textContent = (ev && ev.title) || 'Event';
        ghost.style.left = (t.clientX + 10) + 'px';
        ghost.style.top = (t.clientY + 10) + 'px';
        document.body.appendChild(ghost);
        el.classList.add('dragging');
        if (navigator.vibrate) navigator.vibrate(20);
      }, 400);
    }, { passive: true });
    el.addEventListener('touchmove', function(e) {
      if (longPressTimer && !dragActive) {
        clearTimeout(longPressTimer);
        longPressTimer = null;
      }
      if (!dragActive || !ghost) return;
      e.preventDefault();
      var t = e.touches[0];
      ghost.style.left = (t.clientX + 10) + 'px';
      ghost.style.top = (t.clientY + 10) + 'px';
      highlightTargetAt(t.clientX, t.clientY);
    }, { passive: false });
    el.addEventListener('touchend', function(e) {
      if (longPressTimer) clearTimeout(longPressTimer);
      if (!dragActive) return;
      if (ghost) { ghost.remove(); ghost = null; }
      var t = (e.changedTouches && e.changedTouches[0]);
      if (t) dropAt(t.clientX, t.clientY);
      clearDropHighlights();
      el.classList.remove('dragging');
      state.dragging = null;
      dragActive = false;
    });
  }

  function highlightTargetAt(x, y) {
    clearDropHighlights();
    var target = document.elementFromPoint(x, y);
    if (!target) return;
    var cell = target.closest('.hour-cell, .month-cell');
    if (cell) cell.classList.add('drop-target');
  }
  function clearDropHighlights() {
    Array.prototype.forEach.call(document.querySelectorAll('.drop-target'), function(el){
      el.classList.remove('drop-target');
    });
  }
  function dropAt(x, y) {
    var target = document.elementFromPoint(x, y);
    if (!target) return;
    var cell = target.closest('.hour-cell, .month-cell');
    if (!cell) return;
    var dateKey = cell.dataset.dateKey;
    var hour = cell.dataset.hour ? parseInt(cell.dataset.hour, 10) : 9;
    if (!dateKey) return;
    var parts = dateKey.split('-');
    var d = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
    handleDrop(d, hour);
  }

  // ============ OWNER MODAL ============
  var modal = document.getElementById('modalBackdrop');
  var titleInput = document.getElementById('titleInput');
  var addressInput = document.getElementById('addressInput');
  var priceInput = document.getElementById('priceInput');
  var dateInput = document.getElementById('dateInput');
  var startInput = document.getElementById('startInput');
  var endInput = document.getElementById('endInput');
  var notesInput = document.getElementById('notesInput');
  var deleteBtn = document.getElementById('deleteBtn');
  var duplicateBtn = document.getElementById('duplicateBtn');
  var gcalBtn = document.getElementById('gcalBtn');
  var titleLabel = document.getElementById('titleLabel');
  var addressFieldWrap = document.getElementById('addressFieldWrap');
  var priceFieldWrap = document.getElementById('priceFieldWrap');

  function openModalForNew(date, hour) {
    state.editingId = null;
    document.getElementById('modalTitle').textContent = 'New Event';
    deleteBtn.style.display = 'none';
    duplicateBtn.style.display = 'none';
    gcalBtn.style.display = 'none';
    setType('job');
    titleInput.value = '';
    addressInput.value = '';
    priceInput.value = '';
    notesInput.value = '';
    dateInput.value = fmtDateKey(date);
    var sh = String(hour || 9).padStart(2,'0');
    startInput.value = sh + ':00';
    var endH = Math.min(21, (hour || 9) + 2);
    endInput.value = String(endH).padStart(2,'0') + ':00';
    openModal();
  }

  function openModalForEdit(id) {
    var ev = state.events.find(function(x){ return x.id === id; });
    if (!ev) return;
    state.editingId = id;
    document.getElementById('modalTitle').textContent =
      ev.status === 'pending' ? '⏳ Pending Request' : 'Edit Event';
    deleteBtn.style.display = 'inline-block';
    duplicateBtn.style.display = 'inline-block';
    gcalBtn.style.display = 'inline-flex';
    setType(ev.type);
    titleInput.value = ev.title || '';
    addressInput.value = ev.address || '';
    priceInput.value = ev.price || '';
    notesInput.value = ev.notes || '';
    var s = new Date(ev.start);
    var e = new Date(ev.end);
    dateInput.value = fmtDateKey(s);
    startInput.value = String(s.getHours()).padStart(2,'0') + ':' + String(s.getMinutes()).padStart(2,'0');
    endInput.value = String(e.getHours()).padStart(2,'0') + ':' + String(e.getMinutes()).padStart(2,'0');
    openModal();
  }

  function openModal() { modal.classList.add('open'); setTimeout(function(){ titleInput.focus(); titleInput.select(); }, 50); }
  function closeModal() { modal.classList.remove('open'); state.editingId = null; }

  document.getElementById('modalClose').addEventListener('click', closeModal);
  document.getElementById('cancelBtn').addEventListener('click', closeModal);
  modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });

  Array.prototype.forEach.call(document.querySelectorAll('.type-option'), function(opt) {
    opt.addEventListener('click', function(){ setType(opt.dataset.type); });
  });
  function setType(t) {
    state.selectedType = t;
    Array.prototype.forEach.call(document.querySelectorAll('.type-option'), function(o) {
      o.classList.toggle('selected', o.dataset.type === t);
    });
    addressFieldWrap.style.display = (t === 'job') ? 'flex' : 'none';
    priceFieldWrap.style.display = (t === 'job') ? 'flex' : 'none';
    titleLabel.textContent = (t === 'job') ? 'Service / Vehicle' : 'Title';
    titleInput.placeholder = (t === 'job') ? 'e.g. Full detail — 2013 RAV4' : 'e.g. Supply run, dentist';
  }

  document.getElementById('openMapBtn').addEventListener('click', function() {
    var addr = addressInput.value.trim();
    if (!addr) { toast('Enter an address first'); return; }
    var url = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(addr);
    window.open(url, '_blank');
  });

  // ===== GOOGLE CALENDAR PUSH =====
  // Generates a pre-filled Google Calendar link. Clicking it adds the event
  // to your personal Google Cal, which then delivers push notifications
  // via the Google Calendar mobile app.
  gcalBtn.addEventListener('click', function() {
    if (!state.editingId) return;
    var ev = state.events.find(function(x){ return x.id === state.editingId; });
    if (!ev) return;
    var url = buildGcalLink(ev);
    window.open(url, '_blank');
    toast('Opened Google Calendar — tap Save to enable push', 'success');
  });

  function buildGcalLink(ev) {
    function toGcalDate(iso) {
      var d = new Date(iso);
      return d.getUTCFullYear() +
        String(d.getUTCMonth()+1).padStart(2,'0') +
        String(d.getUTCDate()).padStart(2,'0') + 'T' +
        String(d.getUTCHours()).padStart(2,'0') +
        String(d.getUTCMinutes()).padStart(2,'0') + '00Z';
    }
    var title = (ev.type === 'job' ? '🚗 ' : '') + (ev.title || 'Event');
    var details = [];
    if (ev.price) details.push('Price: $' + ev.price);
    if (ev.notes) details.push(ev.notes);
    details.push('---', 'From Mikey\'s Calendar');
    var params = new URLSearchParams({
      action: 'TEMPLATE',
      text: title,
      dates: toGcalDate(ev.start) + '/' + toGcalDate(ev.end),
      details: details.join('\n'),
      location: ev.address || ''
    });
    return 'https://calendar.google.com/calendar/render?' + params.toString();
  }

  document.getElementById('saveBtn').addEventListener('click', function() {
    var title = titleInput.value.trim();
    if (!title) { toast('Title required'); return; }
    var dateStr = dateInput.value;
    var startParts = (startInput.value || '09:00').split(':');
    var endParts = (endInput.value || '10:00').split(':');
    var start = new Date(dateStr + 'T' + String(startParts[0]).padStart(2,'0') + ':' + String(startParts[1]).padStart(2,'0'));
    var end = new Date(dateStr + 'T' + String(endParts[0]).padStart(2,'0') + ':' + String(endParts[1]).padStart(2,'0'));
    if (end <= start) { toast('End must be after start'); return; }

    var existing = state.editingId ? state.events.find(function(x){ return x.id === state.editingId; }) : null;

    var ev = {
      id: state.editingId || ('ev_' + Date.now() + '_' + Math.random().toString(36).slice(2,7)),
      type: state.selectedType,
      title: title,
      address: state.selectedType === 'job' ? addressInput.value.trim() : '',
      price: state.selectedType === 'job' ? priceInput.value.trim() : '',
      start: start.toISOString(),
      end: end.toISOString(),
      notes: notesInput.value.trim(),
      status: existing ? existing.status : 'confirmed',
      customer: existing ? existing.customer : null,
      updated: Date.now()
    };
    persistEvent(ev).then(function() {
      toast(state.editingId ? 'Saved' : 'Event added', 'success');
      closeModal();
      render();
    });
  });

  deleteBtn.addEventListener('click', function() {
    if (!state.editingId) return;
    if (!confirm('Delete this event?')) return;
    var id = state.editingId;
    removeEventServer(id).then(function() {
      toast('Deleted');
      closeModal();
      render();
    });
  });

  duplicateBtn.addEventListener('click', function() {
    if (!state.editingId) return;
    var ev = state.events.find(function(x){ return x.id === state.editingId; });
    if (!ev) return;
    var origStart = new Date(ev.start);
    var origEnd = new Date(ev.end);
    var newStart = addDays(origStart, 1);
    var newEnd = addDays(origEnd, 1);
    var copy = {
      id: 'ev_' + Date.now() + '_' + Math.random().toString(36).slice(2,7),
      type: ev.type,
      title: ev.title,
      address: ev.address || '',
      price: ev.price || '',
      start: newStart.toISOString(),
      end: newEnd.toISOString(),
      notes: ev.notes || '',
      status: 'confirmed',
      updated: Date.now()
    };
    persistEvent(copy).then(function() {
      toast('Duplicated to ' + newStart.toLocaleDateString('en-US',{month:'short',day:'numeric'}), 'success');
      closeModal();
      render();
    });
  });

  // ============ CUSTOMER BOOKING ============
  var bookingModal = document.getElementById('bookingBackdrop');
  function openBookingModal(date, hour) {
    state.pendingBookingSlot = { date: date, hour: hour };
    var start = new Date(date); start.setHours(hour, 0, 0, 0);
    document.getElementById('bookingTimeDisplay').textContent =
      start.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'}) + ' at ' + fmtTime(start);
    document.getElementById('bookingName').value = '';
    document.getElementById('bookingPhone').value = '';
    document.getElementById('bookingVehicle').value = '';
    document.getElementById('bookingAddress').value = '';
    document.getElementById('bookingNotes').value = '';
    bookingModal.classList.add('open');
  }
  function closeBookingModal() { bookingModal.classList.remove('open'); }
  document.getElementById('bookingClose').addEventListener('click', closeBookingModal);
  document.getElementById('bookingCancel').addEventListener('click', closeBookingModal);
  bookingModal.addEventListener('click', function(e){ if (e.target === bookingModal) closeBookingModal(); });

  document.getElementById('bookingSubmit').addEventListener('click', function() {
    var name = document.getElementById('bookingName').value.trim();
    var phone = document.getElementById('bookingPhone').value.trim();
    if (!name || !phone) { toast('Name and phone required'); return; }
    var svcParts = document.getElementById('bookingService').value.split('|');
    var serviceName = svcParts[0];
    var servicePrice = svcParts[1];
    var vehicle = document.getElementById('bookingVehicle').value.trim();
    var address = document.getElementById('bookingAddress').value.trim();
    var notes = document.getElementById('bookingNotes').value.trim();

    var slot = state.pendingBookingSlot;
    var start = new Date(slot.date); start.setHours(slot.hour, 0, 0, 0);
    // Service duration by type: Full=3.5h, Interior=2.5h, Exterior=2h
    var hours = serviceName === 'Full Detail' ? 3.5 : serviceName === 'Interior Detail' ? 2.5 : 2;
    var end = new Date(start.getTime() + hours * 3600000);

    var ev = {
      id: 'ev_' + Date.now() + '_' + Math.random().toString(36).slice(2,7),
      type: 'job',
      title: serviceName + (vehicle ? ' — ' + vehicle : ''),
      address: address,
      price: servicePrice,
      start: start.toISOString(),
      end: end.toISOString(),
      notes: notes,
      status: 'pending',
      customer: { name: name, phone: phone, vehicle: vehicle },
      updated: Date.now()
    };
    persistEvent(ev).then(function() {
      closeBookingModal();
      toast('Request submitted! Mikey will confirm shortly.', 'success');
      render();
    });
  });

  // ============ PENDING REQUESTS PANEL ============
  var requestsPanel = document.getElementById('requestsPanel');
  document.getElementById('pendingBadge').addEventListener('click', function() {
    renderRequestsPanel();
    requestsPanel.classList.add('open');
  });
  document.getElementById('requestsClose').addEventListener('click', function() {
    requestsPanel.classList.remove('open');
  });

  function updatePendingBadge() {
    var pending = state.events.filter(function(ev){ return ev.status === 'pending'; });
    var badge = document.getElementById('pendingBadge');
    document.getElementById('pendingCount').textContent = pending.length;
    badge.classList.toggle('hidden', pending.length === 0 || state.mode !== 'owner');
  }

  function renderRequestsPanel() {
    var body = document.getElementById('requestsBody');
    var pending = state.events
      .filter(function(ev){ return ev.status === 'pending'; })
      .sort(function(a,b){ return new Date(a.start) - new Date(b.start); });
    if (pending.length === 0) {
      body.innerHTML = '<div class="upcoming-empty">No pending requests</div>';
      return;
    }
    body.innerHTML = '';
    pending.forEach(function(ev) {
      var d = new Date(ev.start);
      var card = document.createElement('div');
      card.className = 'request-card';
      var c = ev.customer || {};
      card.innerHTML =
        '<div class="req-when">' + d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}) +
        ' · ' + fmtTime(d) + ' – ' + fmtTime(new Date(ev.end)) + '</div>' +
        '<div class="req-service">' + escapeHtml(ev.title) + (ev.price ? ' · $' + ev.price : '') + '</div>' +
        '<div class="req-customer">' +
          '<strong>' + escapeHtml(c.name || '—') + '</strong><br>' +
          '📞 <a href="tel:' + escapeHtml(c.phone || '') + '" style="color:var(--text-dim)">' + escapeHtml(c.phone || '—') + '</a>' +
          (ev.address ? '<br>📍 ' + escapeHtml(ev.address) : '') +
          (ev.notes ? '<br>📝 ' + escapeHtml(ev.notes) : '') +
        '</div>' +
        '<div class="req-actions">' +
          '<button class="btn-success" data-act="approve" data-id="' + ev.id + '">✓ Approve</button>' +
          '<button class="btn-danger" data-act="deny" data-id="' + ev.id + '">✗ Deny</button>' +
          '<button class="btn-ghost" data-act="text" data-id="' + ev.id + '">💬 Text</button>' +
        '</div>';
      body.appendChild(card);
    });

    // wire buttons
    body.querySelectorAll('[data-act]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var act = btn.dataset.act;
        var id = btn.dataset.id;
        var ev = state.events.find(function(x){ return x.id === id; });
        if (!ev) return;
        if (act === 'approve') {
          ev.status = 'confirmed';
          ev.updated = Date.now();
          persistEvent(ev).then(function() {
            toast('Approved — tap event to add to Google Calendar', 'success');
            renderRequestsPanel();
            render();
          });
        } else if (act === 'deny') {
          if (!confirm('Deny this request and delete it?')) return;
          removeEventServer(id).then(function() {
            toast('Request denied');
            renderRequestsPanel();
            render();
          });
        } else if (act === 'text') {
          var c = ev.customer || {};
          var phone = (c.phone || '').replace(/\D/g,'');
          var msg = 'Hey ' + (c.name || '').split(' ')[0] + ', this is Mikey from Mikey\'s Mobile Detailing. ' +
                   'Just confirming your ' + ev.title + ' for ' +
                   new Date(ev.start).toLocaleDateString('en-US',{weekday:'long',month:'short',day:'numeric'}) +
                   ' at ' + fmtTime(new Date(ev.start)) + '. Sound good?';
          window.open('sms:' + phone + '?&body=' + encodeURIComponent(msg), '_self');
        }
      });
    });
  }

  // ============ MODE SWITCHER ============
  document.querySelectorAll('#modeSwitcher button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      setMode(btn.dataset.mode);
    });
  });

  function setMode(mode) {
    state.mode = mode;
    document.querySelectorAll('#modeSwitcher button').forEach(function(b) {
      b.classList.toggle('active', b.dataset.mode === mode);
    });
    document.getElementById('palette').classList.toggle('customer-mode', mode === 'customer');
    document.getElementById('customerBanner').classList.toggle('active', mode === 'customer');
    document.getElementById('ownerActions').style.display = mode === 'customer' ? 'none' : 'flex';
    // Customer mode defaults to week view so they can see open slots
    if (mode === 'customer' && state.view === 'month') state.view = 'week';
    render();
  }

  // ============ TOOLBAR ============
  document.getElementById('prevBtn').addEventListener('click', function(){ shift(-1); });
  document.getElementById('nextBtn').addEventListener('click', function(){ shift(1); });
  document.getElementById('todayBtn').addEventListener('click', function(){ state.cursor = new Date(); render(); });
  function shift(dir) {
    if (state.view === 'day') state.cursor = addDays(state.cursor, dir);
    else if (state.view === 'week') state.cursor = addDays(state.cursor, dir * 7);
    else state.cursor = new Date(state.cursor.getFullYear(), state.cursor.getMonth() + dir, 1);
    render();
  }
  Array.prototype.forEach.call(document.querySelectorAll('.view-switcher button'), function(b) {
    b.addEventListener('click', function(){ state.view = b.dataset.view; render(); });
  });

  document.getElementById('newEventBtn').addEventListener('click', function(){ openModalForNew(state.cursor, 9); });

  document.getElementById('exportBtn').addEventListener('click', function() {
    var data = JSON.stringify({ exportedAt: new Date().toISOString(), events: state.events }, null, 2);
    var blob = new Blob([data], { type: 'application/json' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'mikeys-calendar-' + fmtDateKey(new Date()) + '.json';
    a.click();
    URL.revokeObjectURL(url);
    toast('Exported', 'success');
  });

  // ============ TOAST ============
  var toastTimer;
  function toast(msg, variant) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.remove('success');
    if (variant === 'success') t.classList.add('success');
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function(){ t.classList.remove('show'); }, 2800);
  }

  // ============ INIT ============
  // Auto-detect if URL has ?book — default to customer mode (for embedding on site)
  if (window.location.search.indexOf('book') >= 0) {
    setMode('customer');
  }

  loadEvents().then(function() {
    render();
    setTimeout(function() {
      if (state.view !== 'month') document.getElementById('calendarArea').scrollTop = 40;
    }, 100);
  });
})();
</script>
</body>
</html>
