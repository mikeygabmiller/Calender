      <div class="range-label" id="rangeLabel"></div>
    </div>
    <div class="view-switcher">
      <button data-view="day">Day</button>
      <button data-view="week" class="active">Week</button>
      <button data-view="month">Month</button>
    </div>
    <div class="actions" id="ownerActions">
      <button class="btn-ghost" id="exportBtn">Export</button>
      <button class="btn-primary" id="newEventBtn">+ New</button>
    </div>
  </div>

  <!-- Drag blocks palette -->
  <div class="palette" id="palette">
    <div class="palette-label">Blocks:</div>
    <div class="preset" data-type="job" data-draggable="true">
      <div class="preset-dot job"></div>
      <div>Job</div>
    </div>
    <div class="preset" data-type="personal" data-draggable="true">
      <div class="preset-dot personal"></div>
      <div>Personal</div>
    </div>
    <div class="palette-hint">Drag a block onto a time slot → tap the event to rename</div>
  </div>

  <div class="main-area">
    <div class="calendar-area" id="calendarArea"></div>

    <!-- SIDEBAR: stats + upcoming -->
    <aside class="sidebar" id="sidebar">
      <div>
        <div class="side-title">This Week</div>
        <div class="stats-grid">
          <div class="stat-card accent">
            <div class="stat-label">Revenue</div>
            <div class="stat-value red" id="statRevenue">$0</div>
            <div class="stat-sub" id="statRevenueSub">0 jobs</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Hours</div>
            <div class="stat-value" id="statHours">0</div>
            <div class="stat-sub" id="statHoursSub">booked</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Today</div>
            <div class="stat-value" id="statToday">0</div>
            <div class="stat-sub" id="statTodaySub">jobs</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Next Job</div>
            <div class="stat-value" id="statNext" style="font-size:14px">—</div>
            <div class="stat-sub" id="statNextSub"></div>
          </div>
        </div>
      </div>
      <div>
        <div class="side-title">Upcoming (Next 7 Days)</div>
        <div class="upcoming-list" id="upcomingList"></div>
      </div>
    </aside>
  </div>
</div>

